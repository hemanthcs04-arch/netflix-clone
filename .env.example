# TMDB (required) — https://www.themoviedb.org/settings/api
# Use your API Read Access Token (recommended — matches Bearer curl auth):
VITE_TMDB_ACCESS_TOKEN=your_access_token_here

# Or use v3 API Key instead:
VITE_TMDB_API_KEY=

# YouTube Data API v3 (optional fallback when TMDB has no trailer)
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here
